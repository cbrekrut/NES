# Python
__pycache__/
*.py[cod]
*$py.class

# Виртуальное окружение
.venv/
venv/
env/

# Django
# Собранная статика (collectstatic) — генерируется на сервере, в git не нужна.
/static/
/staticfiles/
# Загруженные через админку медиа-файлы.
/media/
/NES/media/

# Локальные секреты/окружение
.env
.env.*

# ОС / редактор
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/

# Примечание: db.sqlite3 НЕ игнорируется намеренно — он уже под версионным
# контролем, а боевая БД живёт на сервере. Не удаляйте его из git без
# согласования: при деплое `git pull` иначе может затереть данные.
